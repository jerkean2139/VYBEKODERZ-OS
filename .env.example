# VybeKoderz AI Agent OS — Environment Variables

# Database (PostgreSQL — required for persistence, job queue, sessions)
DATABASE_URL=postgresql://user:password@localhost:5432/vybeos

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Auth (JWT)
JWT_SECRET=your-jwt-secret-change-in-production

# Auth (OAuth — register apps at Google Cloud Console + Azure Portal)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Voice (optional — simulated without keys)
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Browser Agent (optional — simulated without keys)
BROWSERBASE_API_KEY=your-browserbase-api-key
BROWSERBASE_PROJECT_ID=your-browserbase-project-id

# Artifact Storage (S3-compatible — optional, metadata-only without keys)
S3_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=vybeos-artifacts
S3_REGION=auto

# App URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
PORT=3001
